:root{
  --btn-bg: #007bff;
  --btn-color: #ffffff;
  --btn-radius: 6px;
  --btn-padding: 10px 18px;
  --btn-transition: 160ms;
}

/* Universal button */
.btn{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: .5rem;
  padding: var(--btn-padding);
  font-size: 16px;
  border-radius: var(--btn-radius);
  background: var(--btn-bg);
  color: var(--btn-color);
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: transform var(--btn-transition), filter var(--btn-transition), box-shadow var(--btn-transition);
}

/* Interaction states */
.btn:hover{ transform: translateY(-1px); filter: brightness(.97); }
.btn:active{ transform: translateY(0); }
.btn:focus{ outline: 3px solid rgba(0,123,255,0.22); outline-offset: 2px; }
.btn[disabled], .btn:disabled{ opacity:.6; cursor:not-allowed; pointer-events:none; }

/* Variants */
.btn-outline{ background: transparent; color: var(--btn-bg); border: 2px solid var(--btn-bg); }
.btn-ghost{ background: transparent; color: var(--btn-bg); box-shadow:none; }

/* Sizes */
.btn-sm{ padding:6px 10px; font-size:14px; }
.btn-lg{ padding:14px 22px; font-size:18px; }